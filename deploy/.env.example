# =============================================================================
# ProduktívPro — Unraid szerver .env
# =============================================================================
# Másold ezt a fájlt: /mnt/user/appdata/produktivpro/.env
# (NE commitold a tényleges .env fájlt a repo-ba!)
#
# A docker-compose.yml ebből az .env fájlból olvassa a változókat.
#
# BIZTONSÁGI ELLENŐRZŐLISTA telepítés előtt:
#   [ ] JWT_SECRET: erős, véletlen string (lásd alább a generálást)
#   [ ] CORS_ORIGIN: ha internet-elérés van, domain-re korlátozva
#   [ ] DEFAULT_ADMIN_PIN: az első belépés után azonnal cseréld fel
#   [ ] COOKIE_SECURE: true, ha saját SSL tanúsítványod van
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub Container Registry — a repo neve (kisbetűs!)
# Pl. ha a repo: https://github.com/daniel-vegvari/produktivpro-tir
#   GITHUB_OWNER=daniel-vegvari
#   GITHUB_REPO=produktivpro-tir
# -----------------------------------------------------------------------------
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# -----------------------------------------------------------------------------
# Frontend port (LAN hozzáférés: http://<unraid-ip>:8080)
# -----------------------------------------------------------------------------
FRONTEND_PORT=8080

# -----------------------------------------------------------------------------
# JWT Secret — KÖTELEZŐ, legalább 32 karakter!
# Generálás parancssorból:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=CSERE_EZT_EGY_MINIMUM_32_KARAKTERES_VELETLENSZERU_STRINGRE

# -----------------------------------------------------------------------------
# Admin beállítások (első indításkor hozza létre az admin felhasználót)
# -----------------------------------------------------------------------------
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_PIN=1234

# -----------------------------------------------------------------------------
# Session TTL (másodpercben) — alapértelmezett: 8 óra
# -----------------------------------------------------------------------------
SESSION_TTL_SECONDS=28800

# -----------------------------------------------------------------------------
# Cookie biztonsági beállítás
# false = HTTP is elfogadható (LAN / Cloudflare Tunnel — ő kezeli az SSL-t)
# true  = HTTPS kötelező (ha saját SSL tanúsítványod van)
# AJÁNLÁS: ha Cloudflare Tunnel mögött fut → false (Cloudflare intézi az SSL-t)
#          ha közvetlen HTTPS-en érhető el → true
# -----------------------------------------------------------------------------
COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing) — BIZTONSÁGI BEÁLLÍTÁS!
# *  = mindenki elérhet (LAN-only esetén elfogadható)
# Ha az app elérhető az internetről, szűkítsd a saját domain-re!
# Pl.: CORS_ORIGIN=https://produktivpro.pelda.hu
# Több domain (vesszővel): CORS_ORIGIN=https://a.hu,https://b.hu
# -----------------------------------------------------------------------------
CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# Cloudflare Tunnel token — csak ha a `cloudflare` profillal indítod
# https://one.dash.cloudflare.com/ → Networks → Tunnels → Create tunnel
# -----------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=
