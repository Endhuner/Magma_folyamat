# =============================================================================
# .gitignore — ProduktívPro
# =============================================================================

# Függőségek
node_modules
apps/*/node_modules
packages/*/node_modules

# Build outputok
dist
dist-ssr
*-dist
apps/*/dist

# Lokális adatok — SOHA ne kerüljön repo-ba!
apps/api/data
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Titkok és env fájlok
.env
.env.local
.env.*.local
**/.env
# .env.example és .env.example.* MEGENGEDETT (nincs titok bennük)

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logok
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Egyéb
.file-manifest
.devcontainer/
pids
