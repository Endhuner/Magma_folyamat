# --- ProduktívPro API környezeti változók ---

# A port, amelyen a Fastify szerver figyel.
PORT=5050

# Hostname (Docker-ben 0.0.0.0 javasolt, lokális dev-en 127.0.0.1 elég).
HOST=0.0.0.0

# SQLite adatbázis fájl elérési útja. Docker volume-ra mappelve.
DATABASE_FILE=./data/produktivpro.sqlite

# Engedélyezett origin-ek a CORS-hoz (vesszővel elválasztva, vagy * mindenkinek).
CORS_ORIGIN=http://localhost:5173,http://localhost:5000

# Naplózási szint: 'fatal' | 'error' | 'warn' | 'info' | 'debug' | 'trace'
LOG_LEVEL=info

# Az audit-log eseményekhez használt alapértelmezett felhasználónév, ha
# a kérés nem tartalmaz hitelesített usert (pl. health-check, bootstrap).
DEFAULT_AUDIT_USER=system

# --- Phase 3: autentikáció ---

# JWT aláíró kulcs. PRODUCTION-ben generálj egyet:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Ha nem állítod be, a szerver indulás közben generál egyet, de minden
# restart kijelentkezteti a felhasználókat — ezt sose használd prod-ban.
JWT_SECRET=

# Cookie élettartam (másodperc). Default 8 óra.
SESSION_TTL_SECONDS=28800

# A cookie Secure flag-je. Lokális HTTP fejlesztéshez 'false', éles HTTPS-en 'true'.
COOKIE_SECURE=false

# Bootstrap admin user — első indításnál (ha nincs admin a DB-ben) létrehoz.
# A DEFAULT_ADMIN_PIN bcrypt-elve kerül a DB-be.
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_PIN=1234
